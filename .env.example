# SQLite database location (relative to the prisma/ directory).
DATABASE_URL="file:./dev.db"

# Password required to access the admin upload area (/admin).
# Change this to a strong secret before deploying.
ADMIN_PASSWORD="changeme"

# GitHub account whose public repositories power the "Live work" portfolio.
# Resolution order: admin DB setting → this env var → github.config.json (committed).
GITHUB_USERNAME="TheMitchyBoy"

# Optional GitHub personal access token (classic or fine-grained, read-only).
# Raises the API rate limit from 60 to 5000 req/hr and enables richer deployment
# status. A token with public repo read access is enough.
GITHUB_TOKEN=""
